---
import Layout from '../layouts/Layout.astro';
import archive from '../data/archive.json';

const items = archive.items ?? [];
const folders = [...new Set(items.map((item) => item.folder))].sort();

function formatBytes(bytes) {
  if (!bytes) return '0 B';
  const units = ['B', 'KB', 'MB', 'GB'];
  let value = bytes;
  let unit = 0;
  while (value >= 1024 && unit < units.length - 1) {
    value /= 1024;
    unit += 1;
  }
  return `${value.toFixed(unit === 0 ? 0 : 1)} ${units[unit]}`;
}

function slugify(value) {
  return value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---

<Layout title="Ronald Lee Pyer Photo Archive">
  <main class="page">
    <section class="hero">
      <p class="eyebrow">Archive preview</p>
      <h1>Ronald Lee Pyer Photo Archive</h1>
      <p class="lede">
        A public archive in progress preserving scanned 35mm photographs by Ronald Lee Pyer,
        prepared for publication by Jarad Ronald Peckenpaugh.
      </p>
      <div class="stats">
        <div class="stat">
          <span class="label">Images in preview</span>
          <strong>{archive.item_count}</strong>
        </div>
        <div class="stat">
          <span class="label">Collections represented</span>
          <strong>{folders.length}</strong>
        </div>
        <div class="stat">
          <span class="label">License</span>
          <strong>CC0</strong>
        </div>
      </div>
    </section>

    <section class="panel note">
      <h2>Rights and reuse</h2>
      <p>
        This archive is being prepared for publication under CC0 1.0 Universal. Attribution is not required,
        but appreciated. Suggested credit: <em>{archive.credit_line}</em>
      </p>
    </section>

    <section class="panel">
      <h2>Collections</h2>
      <div class="collections">
        {folders.map((folder) => {
          const count = items.filter((item) => item.folder === folder).length;
          return (
            <a class="collection-card" href={`/collection/${slugify(folder)}/`}>
              <span>{folder}</span>
              <strong>{count} images</strong>
            </a>
          );
        })}
      </div>
    </section>

    <section class="panel">
      <div class="section-header">
        <h2>Browse preview images</h2>
        <label class="filter-label">
          Filter by collection
          <select id="folderFilter">
            <option value="all">All collections</option>
            {folders.map((folder) => <option value={folder}>{folder}</option>)}
          </select>
        </label>
      </div>

      <div class="grid" id="photoGrid">
        {items.map((item) => (
          <article class="photo-card" data-folder={item.folder}>
            <a href={`/photo/${item.id}/`}>
              <img
                src={item.thumb.src}
                alt={item.filename}
                width={item.thumb.width}
                height={item.thumb.height}
                loading="lazy"
              />
            </a>
            <div class="card-body">
              <p class="filename">{item.filename}</p>
              <p class="meta">{item.folder}</p>
              <p class="meta">{item.width} × {item.height} · {formatBytes(item.size_bytes)}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script>
    const filter = document.getElementById('folderFilter');
    const cards = Array.from(document.querySelectorAll('[data-folder]'));

    filter?.addEventListener('change', () => {
      const value = filter.value;
      for (const card of cards) {
        const show = value === 'all' || card.dataset.folder === value;
        card.style.display = show ? '' : 'none';
      }
    });
  </script>
</Layout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }
  .hero { padding: 2rem 0 2.5rem; }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
  }
  h1 {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin: 0 0 1rem;
  }
  h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.35rem;
  }
  .lede {
    font-size: 1.15rem;
    line-height: 1.7;
    max-width: 48rem;
    color: var(--accent);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .stat,
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
  }
  .label,
  .meta { color: var(--muted); }
  .stat strong {
    display: block;
    font-size: 1.6rem;
    margin-top: 0.35rem;
  }
  .panel { margin-top: 1.25rem; }
  .note p {
    margin: 0;
    line-height: 1.8;
  }
  .collections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .collection-card {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--panel-2);
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .filter-label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.95rem;
  }
  select {
    background: var(--panel-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.8rem;
    min-width: 220px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .photo-card {
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .photo-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    background: #0b1220;
  }
  .card-body {
    padding: 0.9rem 1rem 1rem;
  }
  .filename {
    margin: 0 0 0.35rem;
    font-weight: 700;
    overflow-wrap: anywhere;
  }
  .meta {
    margin: 0.15rem 0;
    font-size: 0.95rem;
  }
</style>
