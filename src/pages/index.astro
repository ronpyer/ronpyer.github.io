---
import Layout from '../layouts/Layout.astro';
import archive from '../data/archive.json';
import descriptions from '../data/enrichment/descriptions.json';

function isHiddenTag(tag) {
  return /^book\s+\d+\s*-\s*sheets/i.test(tag);
}

const archiveItems = archive.items ?? [];
const descriptionItems = descriptions.items ?? [];
const descriptionById = new Map(descriptionItems.map((item) => [item.id, item]));

const items = archiveItems
  .map((item) => {
    const enrichment = descriptionById.get(item.id);
    return {
      ...item,
      description: enrichment?.description ?? null,
      searchText: enrichment?.search_text ?? `${item.filename} ${item.folder}`,
      tags: (enrichment?.tags ?? []).filter((tag) => !isHiddenTag(tag.tag)),
    };
  })
  .filter((item) => item.description);

const folders = [...new Set(items.map((item) => item.folder))].sort();
const tagCounts = new Map();
for (const item of items) {
  for (const tag of item.tags) {
    tagCounts.set(tag.tag, (tagCounts.get(tag.tag) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));
const defaultTagCount = 100;

function formatBytes(bytes) {
  if (!bytes) return '0 B';
  const units = ['B', 'KB', 'MB', 'GB'];
  let value = bytes;
  let unit = 0;
  while (value >= 1024 && unit < units.length - 1) {
    value /= 1024;
    unit += 1;
  }
  return `${value.toFixed(unit === 0 ? 0 : 1)} ${units[unit]}`;
}
---

<Layout title="Explore - Ronald Lee Pyer Photo Archive">
  <main class="page">
    <section class="hero">
      <div>
        <h1>Browse the archive by description, tags, and search.</h1>
      </div>
      <div class="hero-actions">
        <a class="button" href="/people/">Browse People</a>
      </div>
    </section>

    <section class="panel controls">
      <label class="search">
        Search
        <input id="searchInput" type="search" placeholder="children, porch, wedding, boat, flowers..." />
      </label>
      <label>
        Collection
        <select id="collectionFilter">
          <option value="all">All collections</option>
          {folders.map((folder) => <option value={folder}>{folder}</option>)}
        </select>
      </label>
      <label>
        Tag
        <select id="tagFilter">
          <option value="all">All tags</option>
          {topTags.map((entry) => <option value={entry.tag}>{entry.tag} ({entry.count})</option>)}
        </select>
      </label>
    </section>

    <section class="panel quick-tags">
      <div class="section-header">
        <div class="section-title">
          <h2>Tags</h2>
          <button type="button" class="toggle-tags-button" id="toggleTagsButton" aria-controls="tagList" aria-expanded="false">
            More
          </button>
        </div>
        <p id="resultsCount">{items.length} photos</p>
      </div>
      <div class="tag-list" id="tagList">
        {topTags.map((entry) => (
          <button class="tag-chip" type="button" data-tag-chip={entry.tag} data-tag-rank={topTags.findIndex((item) => item.tag === entry.tag)}>
            {entry.tag} <span>{entry.count}</span>
          </button>
        ))}
      </div>
    </section>

    <section class="grid" id="exploreGrid">
      {items.map((item) => (
        <article
          class="photo-card"
          data-folder={item.folder}
          data-tags={item.tags.map((tag) => tag.tag.toLowerCase()).join('|')}
          data-search={item.searchText.toLowerCase()}
        >
          <a href={`/photo/${item.id}/`} class="photo-link">
            <img
              src={item.thumb.src}
              alt={item.filename}
              width={item.thumb.width}
              height={item.thumb.height}
              loading="lazy"
            />
          </a>
          <div class="card-body">
            <h2 class="caption"><a href={`/photo/${item.id}/`}>{item.description}</a></h2>
          </div>
        </article>
      ))}
    </section>
  </main>

  <script>
    const searchInput = document.getElementById('searchInput');
    const collectionFilter = document.getElementById('collectionFilter');
    const tagFilter = document.getElementById('tagFilter');
    const cards = Array.from(document.querySelectorAll('.photo-card'));
    const resultsCount = document.getElementById('resultsCount');
    const chips = Array.from(document.querySelectorAll('[data-tag-chip]'));
    const toggleTagsButton = document.getElementById('toggleTagsButton');
    const defaultTagCount = 100;
    const url = new URL(window.location.href);

    function syncUrl() {
      const nextUrl = new URL(window.location.href);
      const search = searchInput?.value.trim() ?? '';
      const collection = collectionFilter?.value ?? 'all';
      const tag = tagFilter?.value ?? 'all';

      if (search) {
        nextUrl.searchParams.set('search', search);
      } else {
        nextUrl.searchParams.delete('search');
      }

      if (collection !== 'all') {
        nextUrl.searchParams.set('collection', collection);
      } else {
        nextUrl.searchParams.delete('collection');
      }

      if (tag !== 'all') {
        nextUrl.searchParams.set('tag', tag);
      } else {
        nextUrl.searchParams.delete('tag');
      }

      history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
    }

    function applyFilters() {
      const search = searchInput?.value.trim().toLowerCase() ?? '';
      const collection = collectionFilter?.value ?? 'all';
      const tag = tagFilter?.value ?? 'all';
      let visible = 0;

      for (const card of cards) {
        const matchesSearch = !search || card.dataset.search.includes(search);
        const matchesCollection = collection === 'all' || card.dataset.folder === collection;
        const matchesTag = tag === 'all' || card.dataset.tags.split('|').includes(tag.toLowerCase());
        const show = matchesSearch && matchesCollection && matchesTag;
        card.style.display = show ? '' : 'none';
        if (show) visible += 1;
      }

      if (resultsCount) {
        resultsCount.textContent = `${visible} photos`;
      }

      for (const chip of chips) {
        chip.classList.toggle('active', tag !== 'all' && chip.dataset.tagChip === tag);
      }

      syncUrl();
    }

    searchInput?.addEventListener('input', applyFilters);
    collectionFilter?.addEventListener('change', applyFilters);
    tagFilter?.addEventListener('change', applyFilters);

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tagChip;
        if (!tagFilter) return;
        tagFilter.value = tagFilter.value === tag ? 'all' : tag;
        applyFilters();
      });
    }

    function applyTagVisibility(showAll = false) {
      for (const chip of chips) {
        const rank = Number(chip.dataset.tagRank ?? '0');
        chip.classList.toggle('is-hidden', !showAll && rank >= defaultTagCount);
      }
      if (toggleTagsButton) {
        toggleTagsButton.textContent = showAll ? 'Less' : 'More';
        toggleTagsButton.setAttribute('aria-expanded', String(showAll));
      }
    }

    if (searchInput) {
      searchInput.value = url.searchParams.get('search') ?? '';
    }

    if (collectionFilter) {
      const initialCollection = url.searchParams.get('collection');
      if (initialCollection && Array.from(collectionFilter.options).some((option) => option.value === initialCollection)) {
        collectionFilter.value = initialCollection;
      }
    }

    if (tagFilter) {
      const initialTag = url.searchParams.get('tag');
      if (initialTag && Array.from(tagFilter.options).some((option) => option.value === initialTag)) {
        tagFilter.value = initialTag;
      }
    }

    applyTagVisibility(false);
    applyFilters();

    toggleTagsButton?.addEventListener('click', () => {
      const showAll = toggleTagsButton.getAttribute('aria-expanded') !== 'true';
      applyTagVisibility(showAll);
    });
  </script>
</Layout>

<style>
  .page {
    max-width: 1260px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }
  .hero {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    line-height: 1.05;
    margin: 0 0 1rem;
    max-width: 14ch;
  }
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.1rem;
    margin-top: 1rem;
  }
  .controls {
    display: grid;
    grid-template-columns: minmax(260px, 2fr) repeat(2, minmax(180px, 1fr));
    gap: 1rem;
  }
  .controls label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.92rem;
  }
  input,
  select {
    background: var(--panel-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-header h2,
  .caption {
    margin: 0;
  }
  .tag-list,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-chip,
  .tag {
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--panel-2);
    color: var(--text);
    padding: 0.45rem 0.75rem;
    font-size: 0.85rem;
  }
  .tag-chip {
    cursor: pointer;
  }
  .toggle-tags-button {
    appearance: none;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    border-radius: 999px;
    padding: 0.4rem 0.75rem;
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .tag-chip.active {
    background: #dbeafe;
    color: #0f172a;
    border-color: #dbeafe;
  }
  .tag-chip.is-hidden {
    display: none;
  }
  .tag span,
  .tag-chip span {
    color: var(--muted);
    margin-left: 0.25rem;
  }
  .tag.zero-shot {
    background: #1f2937;
  }
  .tag.keyword {
    background: #14213d;
  }
  .tag.derived {
    background: #19332d;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .photo-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
  }
  .photo-link img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    background: #0b1220;
  }
  .card-body {
    padding: 1rem;
  }
  .caption {
    font-size: 1.15rem;
    line-height: 1.35;
    margin: 0;
  }
  .button {
    display: inline-block;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .primary {
    background: #e5e7eb;
    color: #111827;
    font-weight: 700;
  }
  @media (max-width: 900px) {
    .hero {
      flex-direction: column;
      align-items: start;
    }
    .controls {
      grid-template-columns: 1fr;
    }
  }
</style>
