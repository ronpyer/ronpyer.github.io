---
import Layout from '../layouts/Layout.astro';
import archive from '../data/archive.json';
import descriptions from '../data/enrichment/descriptions.json';

const archiveItems = archive.items ?? [];
const descriptionItems = descriptions.items ?? [];
const descriptionById = new Map(descriptionItems.map((item) => [item.id, item]));

const items = archiveItems
  .map((item) => {
    const enrichment = descriptionById.get(item.id);
    return {
      ...item,
      description: enrichment?.description ?? null,
      searchText: enrichment?.search_text ?? `${item.filename} ${item.folder}`,
      tags: enrichment?.tags ?? [],
    };
  })
  .filter((item) => item.description);

const folders = [...new Set(items.map((item) => item.folder))].sort();
const tagCounts = new Map();
for (const item of items) {
  for (const tag of item.tags) {
    tagCounts.set(tag.tag, (tagCounts.get(tag.tag) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 24)
  .map(([tag, count]) => ({ tag, count }));

function formatBytes(bytes) {
  if (!bytes) return '0 B';
  const units = ['B', 'KB', 'MB', 'GB'];
  let value = bytes;
  let unit = 0;
  while (value >= 1024 && unit < units.length - 1) {
    value /= 1024;
    unit += 1;
  }
  return `${value.toFixed(unit === 0 ? 0 : 1)} ${units[unit]}`;
}
---

<Layout title="Explore - Ronald Lee Pyer Photo Archive">
  <main class="page">
    <section class="hero">
      <div>
        <h1>Browse the archive by description, tags, and search.</h1>
      </div>
      <div class="hero-actions">
        <a class="button" href="/people/">Browse People</a>
        <a class="button primary" href="/archive/">Open Archive</a>
      </div>
    </section>

    <section class="panel controls">
      <label class="search">
        Search
        <input id="searchInput" type="search" placeholder="children, porch, wedding, boat, flowers..." />
      </label>
      <label>
        Collection
        <select id="collectionFilter">
          <option value="all">All collections</option>
          {folders.map((folder) => <option value={folder}>{folder}</option>)}
        </select>
      </label>
      <label>
        Tag
        <select id="tagFilter">
          <option value="all">All tags</option>
          {topTags.map((entry) => <option value={entry.tag}>{entry.tag} ({entry.count})</option>)}
        </select>
      </label>
    </section>

    <section class="panel quick-tags">
      <div class="section-header">
        <h2>Common tags</h2>
        <p id="resultsCount">{items.length} photos</p>
      </div>
      <div class="tag-list">
        {topTags.map((entry) => (
          <button class="tag-chip" type="button" data-tag-chip={entry.tag}>
            {entry.tag} <span>{entry.count}</span>
          </button>
        ))}
      </div>
    </section>

    <section class="grid" id="exploreGrid">
      {items.map((item) => (
        <article
          class="photo-card"
          data-folder={item.folder}
          data-tags={item.tags.map((tag) => tag.tag.toLowerCase()).join('|')}
          data-search={item.searchText.toLowerCase()}
        >
          <a href={`/photo/${item.id}/`} class="photo-link">
            <img
              src={item.thumb.src}
              alt={item.filename}
              width={item.thumb.width}
              height={item.thumb.height}
              loading="lazy"
            />
          </a>
          <div class="card-body">
            <p class="collection">{item.folder}</p>
            <h2 class="caption"><a href={`/photo/${item.id}/`}>{item.description}</a></h2>
            <p class="filename">{item.filename}</p>
            <p class="meta">{item.width} × {item.height} · {formatBytes(item.size_bytes)}</p>
            <div class="tags">
              {item.tags.slice(0, 6).map((tag) => (
                <span class={`tag ${tag.type}`}>{tag.tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>
  </main>

  <script>
    const searchInput = document.getElementById('searchInput');
    const collectionFilter = document.getElementById('collectionFilter');
    const tagFilter = document.getElementById('tagFilter');
    const cards = Array.from(document.querySelectorAll('.photo-card'));
    const resultsCount = document.getElementById('resultsCount');
    const chips = Array.from(document.querySelectorAll('[data-tag-chip]'));

    function applyFilters() {
      const search = searchInput?.value.trim().toLowerCase() ?? '';
      const collection = collectionFilter?.value ?? 'all';
      const tag = tagFilter?.value ?? 'all';
      let visible = 0;

      for (const card of cards) {
        const matchesSearch = !search || card.dataset.search.includes(search);
        const matchesCollection = collection === 'all' || card.dataset.folder === collection;
        const matchesTag = tag === 'all' || card.dataset.tags.split('|').includes(tag.toLowerCase());
        const show = matchesSearch && matchesCollection && matchesTag;
        card.style.display = show ? '' : 'none';
        if (show) visible += 1;
      }

      if (resultsCount) {
        resultsCount.textContent = `${visible} photos`;
      }

      for (const chip of chips) {
        chip.classList.toggle('active', tag !== 'all' && chip.dataset.tagChip === tag);
      }
    }

    searchInput?.addEventListener('input', applyFilters);
    collectionFilter?.addEventListener('change', applyFilters);
    tagFilter?.addEventListener('change', applyFilters);

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tagChip;
        if (!tagFilter) return;
        tagFilter.value = tagFilter.value === tag ? 'all' : tag;
        applyFilters();
      });
    }
  </script>
</Layout>

<style>
  .page {
    max-width: 1260px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }
  .hero {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.05;
    margin: 0 0 1rem;
    max-width: 14ch;
  }
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.1rem;
    margin-top: 1rem;
  }
  .controls {
    display: grid;
    grid-template-columns: minmax(260px, 2fr) repeat(2, minmax(180px, 1fr));
    gap: 1rem;
  }
  .controls label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.92rem;
  }
  input,
  select {
    background: var(--panel-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .section-header h2,
  .caption {
    margin: 0;
  }
  .tag-list,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-chip,
  .tag {
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--panel-2);
    color: var(--text);
    padding: 0.45rem 0.75rem;
    font-size: 0.85rem;
  }
  .tag-chip {
    cursor: pointer;
  }
  .tag-chip.active {
    background: #dbeafe;
    color: #0f172a;
    border-color: #dbeafe;
  }
  .tag span,
  .tag-chip span {
    color: var(--muted);
    margin-left: 0.25rem;
  }
  .tag.zero-shot {
    background: #1f2937;
  }
  .tag.keyword {
    background: #14213d;
  }
  .tag.derived {
    background: #19332d;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .photo-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
  }
  .photo-link img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    background: #0b1220;
  }
  .card-body {
    padding: 1rem;
  }
  .collection,
  .filename,
  .meta {
    color: var(--muted);
  }
  .collection {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
  }
  .caption {
    font-size: 1.15rem;
    line-height: 1.35;
    margin-bottom: 0.65rem;
  }
  .filename,
  .meta {
    margin: 0.25rem 0;
    font-size: 0.92rem;
  }
  .tags {
    margin-top: 0.9rem;
  }
  .button {
    display: inline-block;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .primary {
    background: #e5e7eb;
    color: #111827;
    font-weight: 700;
  }
  @media (max-width: 900px) {
    .hero {
      flex-direction: column;
      align-items: start;
    }
    .controls {
      grid-template-columns: 1fr;
    }
  }
</style>
