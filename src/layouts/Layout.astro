---
const brand = 'Ronald Lee Pyer Photgraphy';
const { title = 'Ronald Lee Pyer Photo Archive' } = Astro.props;
const pageTitle = title === brand ? brand : `${brand} | ${title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-brand">{brand}</a>
    </header>
    <slot />
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #0f172a;
    --panel: #111827;
    --panel-2: #1f2937;
    --text: #e5e7eb;
    --muted: #94a3b8;
    --accent: #cbd5e1;
    --border: #334155;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    min-height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: Inter, Arial, sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    padding: 0.9rem 1.25rem 0;
  }

  .site-brand {
    display: inline-block;
    color: var(--muted);
    font-size: 1.1rem;
    letter-spacing: 0.01em;
  }
</style>
