# dependencies
node_modules/

# local Astro/cache artifacts
.astro/

# editor/system noise
.vscode/
.DS_Store

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files
.env
.env.*

# Python/cache leftovers if helper scripts get added later
__pycache__/
*.pyc
.venv/
.venv-faces/
.python-version

# local runtime extras
*.pid
.hf-cache/
.torch-cache/
data/archive.db
data/enrichment/private/*
!data/enrichment/private/.gitkeep

# IMPORTANT:
# Keep docs/ tracked because GitHub Pages will publish from /docs
# Keep public/generated site assets if they are part of the project source
